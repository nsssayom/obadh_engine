# Generated by Cargo
# will have compiled files and executables
debug/
target/

# OS/editor noise
.DS_Store
*.bak

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# WebAssembly build artifacts
pkg/

# Node.js
node_modules/
www/node_modules/

# Python/cache noise from local tooling
__pycache__/
*.py[cod]

# Data-heavy autocorrect/autosuggest artifacts live in direct data-only
# submodules at data/autocorrect and data/autosuggest. Scratch outputs stay
# ignored if those paths are used without the submodules.
data/autocorrect/tmp/**
data/autocorrect/candidates/**
data/autocorrect/training/**
data/autosuggest/tmp/**
data/autosuggest/training/**
data/autosuggest/models/neural/dataset/**
data/autosuggest/models/neural/checkpoints*/**
data/autosuggest/models/neural/*.pt

# Local book/corpus drops for manual extraction smoke tests.
epubs/
*.epub
*.EPUB

# Package locks
# Comment the following line if you want to keep package-lock.json in version control
#www/package-lock.json

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Include distribution files needed for GitHub Pages
!www/css/styles.css
!www/js/*.js
!www/js/*.wasm
